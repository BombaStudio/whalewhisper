# =========================================================================
# WhaleWhisper - Environment Variables Configuration Template
# =========================================================================

# --- OKX x402 Payment Facilitator Credentials ---
# Required to interface with the OKX Web3 Payment Facilitator.
# Obtain by registering your project/ASP in the OKX.AI Developer Portal.
OKX_API_KEY="your_okx_api_key_here"
OKX_SECRET_KEY="your_okx_secret_key_here"
OKX_PASSPHRASE="your_okx_passphrase_here"

# --- Target Seller Payment Configuration ---
# The EVM wallet address belonging to the ASP seller that receives the testnet payments.
SELLER_WALLET_ADDRESS="your_seller_evm_wallet_address_here"
NEXT_PUBLIC_SELLER_WALLET_ADDRESS="your_seller_evm_wallet_address_here"

# --- X Layer Testnet Token Contract Addresses ---
# USDC contract address on X Layer Testnet (6 decimals)
NEXT_PUBLIC_TESTNET_USDC_ADDRESS="0xcb8bf24c6ce16ad21d707c9505421a17f2bec79d"
# USDT contract address on X Layer Testnet (6 decimals)
NEXT_PUBLIC_TESTNET_USDT_ADDRESS="0x67a15159048a1c8411c84b423f03b8420b9e29b4"
NEXT_PUBLIC_TESTNET_BTC_ADDRESS="0x1111111111111111111111111111111111111111"
NEXT_PUBLIC_TESTNET_ETH_ADDRESS="0x2222222222222222222222222222222222222222"
NEXT_PUBLIC_TESTNET_SOL_ADDRESS="0x3333333333333333333333333333333333333333"
NEXT_PUBLIC_TESTNET_POPCAT_ADDRESS="0x4444444444444444444444444444444444444444"

# --- OpenRouter AI API Configuration (Optional Fallback) ---
OPENROUTER_API_KEY="your_openrouter_api_key_here"
OPENROUTER_MODEL="google/gemini-2.5-flash"

# --- Application Configuration ---
APP_URL="http://localhost:3000"
NEXT_PUBLIC_ALCHEMY_API_KEY=""
