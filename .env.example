# =========================================================================
# WhaleWhisper - Environment Variables Configuration Template
# =========================================================================

# --- OpenRouter AI API Configuration (Used by WhaleWhisperAgent backend) ---
# Your OpenRouter API Key for AI Model inferences.
# Obtain from: https://openrouter.ai/keys
OPENROUTER_API_KEY="your_openrouter_api_key_here"

# The AI Model to use. Example: google/gemini-2.5-flash or google/gemini-2.5-pro
OPENROUTER_MODEL="google/gemini-2.5-flash"


# --- OKX x402 Payment Facilitator Credentials ---
# These are required to communicate with the OKX Web3 Payment protocol.
# Obtain by registering your project/ASP in the OKX.AI Developer Portal:
# https://web3.okx.com/onchainos/dev-docs/payments
OKX_API_KEY="your_okx_api_key_here"
OKX_SECRET_KEY="your_okx_secret_key_here"
OKX_PASSPHRASE="your_okx_passphrase_here"

# Base URL for the OKX API. Use https://api.okx.com for production.
OKX_BASE_URL="https://api.okx.com"

# --- Target Seller Payment Configuration ---
# The EVM wallet address belonging to the ASP seller that receives the $0.01 Testnet payments.
SELLER_WALLET_ADDRESS="your_seller_evm_wallet_address_here"

# --- Application Configuration ---
# Public URL where the application is hosted (e.g. Vercel deployment URL).
# Use http://localhost:3000 for local development.
APP_URL="http://localhost:3000"

# --- On-Chain Explorer / Data API Configuration ---
# Alchemy API Key for real-time whale transactions fetching (Ethereum Mainnet).
# If left blank, the client automatically falls back to Blockscout.
NEXT_PUBLIC_ALCHEMY_API_KEY=""
